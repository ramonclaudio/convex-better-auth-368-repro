# Convex deployment name. Format: dev:<adjective>-<noun>-<number>
# Example: dev:happy-animal-123
CONVEX_DEPLOYMENT=

# Convex client URL. Same slug as the deployment, .convex.cloud host.
# Example: https://happy-animal-123.convex.cloud
EXPO_PUBLIC_CONVEX_URL=

# Convex HTTP actions URL. Same slug, .convex.site host.
# Used as Better Auth's baseURL.
# Example: https://happy-animal-123.convex.site
EXPO_PUBLIC_CONVEX_SITE_URL=
